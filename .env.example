# Copy this file to .env and fill in values for local development.
# Never commit .env to git.

# Paths to trained model artifacts (relative to project root or absolute)
MODEL_PATH=fruit_freshness_regression.keras
SCALER_PATH=target_scaler.save

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum accepted upload size in megabytes
MAX_FILE_SIZE_MB=10

# API key for programmatic access.
# Leave empty to allow public access (rate limiting still applies).
# Set to a strong random string in production to restrict access.
API_KEY=

# Comma-separated list of allowed CORS origins.
# In production, set this to your Vercel frontend URL.
# Example: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
